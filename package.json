{
  "name": "preqstation",
  "version": "0.1.2",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "eval $(grep '^PORT=' .env.local 2>/dev/null); next dev -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@js-temporal/polyfill": "^0.5.1",
    "@lexical/code": "^0.22.0",
    "@lexical/link": "^0.22.0",
    "@lexical/list": "^0.22.0",
    "@lexical/markdown": "^0.22.0",
    "@lexical/react": "^0.22.0",
    "@lexical/rich-text": "^0.22.0",
    "@mantine/charts": "^9.0.2",
    "@mantine/core": "^9.0.2",
    "@mantine/hooks": "^9.0.2",
    "@mantine/notifications": "^9.0.2",
    "@mantine/spotlight": "^9.0.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@tabler/icons-react": "^3.38.0",
    "any-ascii": "^0.3.3",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "fractional-indexing": "^3.2.0",
    "idb": "^8.0.3",
    "lexical": "^0.22.0",
    "next": "^16.1.6",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.3.2",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
