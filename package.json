{
  "name": "preqstation",
  "version": "0.1.4",
  "private": false,
  "license": "MIT",
  "bin": {
    "preqstation": "bin/preqstation.mjs"
  },
  "scripts": {
    "dev": "eval $(grep '^PORT=' .env.local 2>/dev/null); next dev -p ${PORT:-3000}",
    "build": "node scripts/build.mjs",
    "build:cloudflare": "node scripts/build.mjs --cloudflare",
    "deploy:cloudflare": "opennextjs-cloudflare deploy -- --keep-vars",
    "upload:cloudflare": "opennextjs-cloudflare upload -- --keep-vars",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@js-temporal/polyfill": "^0.5.1",
    "@lexical/code": "^0.45.0",
    "@lexical/code-core": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/markdown": "^0.46.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@mantine/charts": "^9.4.0",
    "@mantine/core": "^9.4.0",
    "@mantine/hooks": "^9.4.0",
    "@mantine/notifications": "^9.4.0",
    "@mantine/spotlight": "^9.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tabler/icons-react": "^3.44.0",
    "@xyflow/react": "^12.11.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fractional-indexing": "^3.2.0",
    "idb": "^8.0.3",
    "lexical": "^0.45.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.9",
    "otpauth": "^9.5.1",
    "postgres": "^3.4.8",
    "re-resizable": "^6.11.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "lexical": "$lexical"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.3.2",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.102.0"
  }
}
