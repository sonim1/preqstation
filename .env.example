# =============================================================================
# Preq Station — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# All variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enhance functionality but are not required.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# [REQUIRED] Session signing secret for HMAC cookie signatures.
# Must be at least 16 characters. Longer is better.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Owner login credentials are stored in the `users` table.
# Fresh installs show owner setup on /login. See docs/setup.md for manual SQL setup.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma or newline-separated origins for CORS / server action checks.
# Include your production, preview, or Cloudflare custom-domain origins.
# Example: https://your-app.vercel.app,https://preview.example.com,https://tasks.example.com
ALLOWED_ORIGINS=

# Project background search uses Openverse and does not require an API key.

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------

# [OPTIONAL] Secret token used to authenticate Vercel cron job requests.
# Set this to a random string and configure it in your Vercel project env vars.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# events_outbox cleanup currently retains one day of events.
