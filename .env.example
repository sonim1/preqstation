# =============================================================================
# Preq Station — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# All variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enhance functionality but are not required.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# [REQUIRED] Session signing secret for HMAC cookie signatures.
# Must be at least 16 characters. Longer is better.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Owner login credentials are stored in the `users` table.
# After running migrations, create or update the owner row manually.
# See docs/setup.md for the bcrypt + SQL provisioning flow.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma or newline-separated origins for CORS / server action checks.
# Include your Vercel production and preview URLs.
# Example: https://your-app.vercel.app,https://your-app-git-main-user.vercel.app
ALLOWED_ORIGINS=

# [OPTIONAL] Unsplash access key used by the project background picker search proxy.
# Create an app and key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------

# [OPTIONAL] Secret token used to authenticate Vercel cron job requests.
# Set this to a random string and configure it in your Vercel project env vars.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# [OPTIONAL] Number of days to retain events_outbox rows before cleanup.
# Defaults to 30 if not set.
EVENT_OUTBOX_RETENTION_DAYS=30
